{
  "name": "foam-factory-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:start:local && concurrently \"node server/index.js\" \"vite --host 0.0.0.0\"",
    "server": "node server/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:start:local": "powershell -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "db:stop:local": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "mobile:start": "npm --prefix mobile run start -- --lan",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:doctor": "npm --prefix mobile exec expo-doctor"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vitejs/plugin-react": "^5.0.0",
    "ag-grid-community": "^34.0.0",
    "ag-grid-react": "^34.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "prisma": "^7.8.0"
  }
}
