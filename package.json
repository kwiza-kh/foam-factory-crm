{
  "name": "foam-factory-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:start:local && node scripts/dev.mjs",
    "server": "node server/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:start:local": "powershell -ExecutionPolicy Bypass -File scripts/start-local-mysql.ps1",
    "db:stop:local": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-mysql.ps1",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "mobile:start": "npm --prefix mobile run start -- --lan",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:doctor": "npm --prefix mobile exec expo-doctor",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^5.0.0",
    "ag-grid-community": "^34.0.0",
    "ag-grid-react": "^34.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.9.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.8"
  }
}
