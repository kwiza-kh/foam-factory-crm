{
  "expo": {
    "name": "泡沫工厂 CRM",
    "slug": "foam-factory-schedule",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "foamfactorycrm",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F6FA"
    },
    "plugins": [
      "expo-notifications"
    ],
    "ios": {
      "bundleIdentifier": "com.kwizakh.foamfactorycrm",
      "buildNumber": "1.0.0",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "泡沫工厂 CRM",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "用于拍摄订单完成现场照片和物料成本录入照片。",
        "NSPhotoLibraryUsageDescription": "用于在需要时选择订单或物料相关照片。"
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
