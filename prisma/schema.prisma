generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id            String         @id
  name          String
  contact       String         @default("")
  phone         String         @default("")
  address       String         @default("")
  level         String         @default("")
  paymentTerm   String         @default("") @map("payment_term")
  taxNo         String         @default("") @map("tax_no")
  note          String         @default("")
  customColumns Json           @default("{\"products\":[],\"orders\":[],\"deliveries\":[],\"materialCosts\":[],\"costEntries\":[],\"statements\":[],\"payments\":[]}") @map("custom_columns")
  products      Product[]
  orders        Order[]
  deliveries    Delivery[]
  materialCosts MaterialCost[]
  costEntries   CostEntry[]
  statements    Statement[]
  payments      Payment[]

  @@map("customers")
}

model Product {
  id         String   @id
  customerId String   @map("customer_id")
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "products_customer_idx")
  @@map("products")
}

model Order {
  id         String   @id
  customerId String   @map("customer_id")
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "orders_customer_idx")
  @@map("orders")
}

model Delivery {
  id         String   @id
  customerId String   @map("customer_id")
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "deliveries_customer_idx")
  @@map("deliveries")
}

model MaterialCost {
  id         String   @id
  customerId String   @map("customer_id")
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "material_costs_customer_idx")
  @@map("material_costs")
}

model CostEntry {
  id         String   @id
  customerId String   @map("customer_id")
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "cost_entries_customer_idx")
  @@map("cost_entries")
}

model Statement {
  id         String   @id
  customerId String   @map("customer_id")
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "statements_customer_idx")
  @@map("statements")
}

model Payment {
  id         String   @id
  customerId String   @map("customer_id")
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "payments_customer_idx")
  @@map("payments")
}

model MobileUser {
  id           String   @id
  name         String   @default("")
  phone        String   @unique
  role         String   @default("pending")
  passwordHash String   @default("") @map("password_hash")
  token        String   @unique
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("mobile_users")
}
