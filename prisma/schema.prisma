generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Customer {
  id            String         @id @db.VarChar(191)
  name          String         @db.VarChar(255)
  contact       String         @default("") @db.VarChar(255)
  phone         String         @default("") @db.VarChar(255)
  address       String         @default("") @db.VarChar(255)
  level         String         @default("") @db.VarChar(255)
  paymentTerm   String         @default("") @map("payment_term") @db.VarChar(255)
  taxNo         String         @default("") @map("tax_no") @db.VarChar(255)
  note          String         @default("") @db.VarChar(255)
  customColumns Json           @default("{\"products\":[],\"orders\":[],\"deliveries\":[],\"materialCosts\":[],\"costEntries\":[],\"statements\":[],\"payments\":[]}") @map("custom_columns")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  products      Product[]
  orders        Order[]
  deliveries    Delivery[]
  materialCosts MaterialCost[]
  costEntries   CostEntry[]
  statements    Statement[]
  payments      Payment[]

  @@map("customers")
}

model Product {
  id         String   @id @db.VarChar(191)
  customerId String   @map("customer_id") @db.VarChar(191)
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "products_customer_idx")
  @@index([customerId, sortOrder], map: "products_customer_sort_idx")
  @@map("products")
}

model Order {
  id         String   @id @db.VarChar(191)
  customerId String   @map("customer_id") @db.VarChar(191)
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "orders_customer_idx")
  @@index([customerId, sortOrder], map: "orders_customer_sort_idx")
  @@map("orders")
}

model Delivery {
  id         String   @id @db.VarChar(191)
  customerId String   @map("customer_id") @db.VarChar(191)
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "deliveries_customer_idx")
  @@index([customerId, sortOrder], map: "deliveries_customer_sort_idx")
  @@map("deliveries")
}

model MaterialCost {
  id         String   @id @db.VarChar(191)
  customerId String   @map("customer_id") @db.VarChar(191)
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "material_costs_customer_idx")
  @@index([customerId, sortOrder], map: "material_costs_customer_sort_idx")
  @@map("material_costs")
}

model CostEntry {
  id         String   @id @db.VarChar(191)
  customerId String   @map("customer_id") @db.VarChar(191)
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "cost_entries_customer_idx")
  @@index([customerId, sortOrder], map: "cost_entries_customer_sort_idx")
  @@map("cost_entries")
}

model Statement {
  id         String   @id @db.VarChar(191)
  customerId String   @map("customer_id") @db.VarChar(191)
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "statements_customer_idx")
  @@index([customerId, sortOrder], map: "statements_customer_sort_idx")
  @@map("statements")
}

model Payment {
  id         String   @id @db.VarChar(191)
  customerId String   @map("customer_id") @db.VarChar(191)
  sortOrder  Int      @default(0) @map("sort_order")
  data       Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "payments_customer_idx")
  @@index([customerId, sortOrder], map: "payments_customer_sort_idx")
  @@map("payments")
}

model MobileUser {
  id            String   @id @db.VarChar(191)
  name          String   @default("") @db.VarChar(255)
  phone         String   @unique @db.VarChar(255)
  role          String   @default("pending") @db.VarChar(255)
  avatar        String   @default("") @db.VarChar(255)
  passwordHash  String   @default("") @map("password_hash") @db.VarChar(255)
  token         String   @unique @db.VarChar(255)
  tokenExpiresAt DateTime? @map("token_expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("mobile_users")
}

model AppSetting {
  key       String   @id @db.VarChar(191)
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model AttendanceRecord {
  id        String   @id @db.VarChar(191)
  userId    String   @map("user_id") @db.VarChar(191)
  date      String   @db.VarChar(10)
  checkIn   DateTime? @map("check_in")
  checkOut  DateTime? @map("check_out")
  note      String   @default("") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@map("attendance_records")
}

model LeaveRecord {
  id        String   @id @db.VarChar(191)
  userId    String   @map("user_id") @db.VarChar(191)
  type      String   @db.VarChar(50)
  startDate String   @map("start_date") @db.VarChar(10)
  endDate   String   @map("end_date") @db.VarChar(10)
  reason    String   @default("") @db.VarChar(500)
  status    String   @default("pending") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("leave_records")
}
